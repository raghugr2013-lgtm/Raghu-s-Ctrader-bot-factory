@@ -0,0 +1,75 @@
+from __future__ import annotations
+
+import math
+from statistics import mean
+from typing import Any, Dict, List
+
+
+class StrategyCorrelationEngine:
+    """Analyze candidate strategy correlation from backtest trade returns."""
+
+    def __init__(self, threshold: float = 0.8):
+        self.threshold = threshold
+
+    @staticmethod
+    def build_return_series(trades: List[Any], initial_balance: float) -> List[float]:
+        if initial_balance <= 0:
+            return []
+        returns: List[float] = []
+        for trade in trades:
+            pnl = getattr(trade, "profit_loss", None)
+            if pnl is None:
+                continue
+            returns.append(float(pnl) / float(initial_balance))
+        return returns
+
+    @staticmethod
+    def pearson_correlation(series_a: List[float], series_b: List[float]) -> float:
+        n = min(len(series_a), len(series_b))
+        if n < 2:
+            return 0.0
+
+        a = series_a[:n]
+        b = series_b[:n]
+        mean_a = sum(a) / n
+        mean_b = sum(b) / n
+
+        cov = sum((x - mean_a) * (y - mean_b) for x, y in zip(a, b))
+        var_a = sum((x - mean_a) ** 2 for x in a)
+        var_b = sum((y - mean_b) ** 2 for y in b)
+
+        if var_a <= 0 or var_b <= 0:
+            return 0.0
+
+        corr = cov / math.sqrt(var_a * var_b)
+        return max(-1.0, min(1.0, corr))
+
+    def analyze_candidate(
+        self,
+        candidate_returns: List[float],
+        accepted_rows: List[Dict[str, Any]],
+    ) -> Dict[str, float]:
+        if not accepted_rows:
+            return {
+                "correlation_score": 100.0,
+                "max_correlation": 0.0,
+                "avg_correlation": 0.0,
+                "rejected": False,
+            }
+
+        correlations: List[float] = []
+        for row in accepted_rows:
+            accepted_returns = row.get("returns", [])
+            corr = self.pearson_correlation(candidate_returns, accepted_returns)
+            correlations.append(corr)
+
+        max_corr = max(correlations) if correlations else 0.0
+        avg_corr = mean(correlations) if correlations else 0.0
+        score = 100.0 * (1.0 - max(0.0, max_corr))
+
+        return {
+            "correlation_score": round(score, 4),
+            "max_correlation": round(max_corr, 4),
+            "avg_correlation": round(avg_corr, 4),
+            "rejected": max_corr > self.threshold,
+        }
