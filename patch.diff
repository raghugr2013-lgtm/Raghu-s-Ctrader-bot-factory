+++ b/backend/master_pipeline_controller.py
@@ -0,0 +1,789 @@
+"""
+Master Strategy Pipeline Controller
+Unified pipeline:
+1) Generate strategies
+2) Uniqueness filter
+3) Real-data backtest
+4) Validation (walk-forward + Monte Carlo)
+5) Quality filters
+6) Correlation filter
+7) Market regime detection/adaptation
+8) Portfolio selection
+9) Risk/capital allocation
+10) Capital scaling
+11) Generate cBots
+12) Compile and fix
+13) Return deployable bots + full report
+"""
+
+from __future__ import annotations
+
+import uuid
+from datetime import datetime, timezone, timedelta
+from typing import Any, Dict, List, Optional
+
+from pydantic import BaseModel, Field
+
+from auto_fetch_candles import auto_fetch_candles
+from factory_engine import STRATEGY_TEMPLATES, StrategyGenerator
+from factory_models import TemplateId
+from strategy_diversity_engine import create_strategy_diversity_engine
+from real_backtester import real_backtester
+from backtest_calculator import performance_calculator, strategy_scorer
+from montecarlo_models import MonteCarloConfig
+from montecarlo_engine import create_monte_carlo_engine
+from walkforward_models import WalkForwardConfig
+from walkforward_engine import create_walk_forward_engine
+from multi_ai_engine import create_multi_ai_orchestrator
+from multi_ai_models import AIModel
+from compile_gate import compile_and_verify
+from strategy_correlation_engine import StrategyCorrelationEngine
+from portfolio_selection_engine import PortfolioSelectionEngine
+from risk_allocation_engine import RiskAndCapitalAllocationEngine
+from market_regime_adaptation_engine import MarketRegimeAdaptationEngine
+from capital_scaling_engine import CapitalScalingEngine
+
+
+class MasterPipelineRequest(BaseModel):
+    session_id: Optional[str] = None
+    strategy_prompt: str = "Generate robust FX strategies for prop-firm safe trading."
+    templates: List[TemplateId] = Field(default_factory=lambda: list(TemplateId))
+    strategies_per_template: int = 8
+    symbol: str = "EURUSD"
+    timeframe: str = "1h"
+    start_date: Optional[datetime] = None
+    end_date: Optional[datetime] = None
+    min_candles: int = 2000
+    initial_balance: float = 10000.0
+    top_n: int = 5
+    ai_model: str = "openai"
+    prop_firm: str = "ftmo"
+    monte_carlo_runs: int = 100
+    max_compile_fix_attempts: int = 3
+    correlation_threshold: float = 0.8
+    allocation_method: str = "risk_adjusted"  # "equal_weight" or "risk_adjusted"
+    max_portfolio_drawdown_percent: float = 20.0
+    max_daily_loss_percent: float = 5.0
+    max_trades_per_day: int = 15
+    max_position_size_percent: float = 2.0
+    strategy_stop_drawdown_percent: float = 12.0
+    regime_adaptation_enabled: bool = True
+    capital_scaling_enabled: bool = True
+    scaling_pf_threshold: float = 1.3
+    scaling_max_cap: float = 1.5
+    custom_prop_rules: Optional[Dict[str, Any]] = None
+    prop_rules_confirmed: bool = False
+
+
+class PipelineStageLog(BaseModel):
+    stage: str
+    success: bool
+    message: str
+    details: Dict[str, Any] = Field(default_factory=dict)
+    timestamp: datetime = Field(default_factory=lambda: datetime.now(timezone.utc))
+
+
+class DeployableBot(BaseModel):
+    strategy_id: str
+    template_id: str
+    uniqueness_score: float
+    quality_summary: Dict[str, Any]
+    csharp_code: str
+    compile_status: str
+    compile_errors: List[str] = Field(default_factory=list)
+    compile_warnings: List[str] = Field(default_factory=list)
+
+
+class MasterPipelineReport(BaseModel):
+    success: bool
+    pipeline_id: str
+    session_id: str
+    symbol: str
+    timeframe: str
+    stage_logs: List[PipelineStageLog]
+    generation_summary: Dict[str, Any] = Field(default_factory=dict)
+    validation_summary: Dict[str, Any] = Field(default_factory=dict)
+    selection_summary: Dict[str, Any] = Field(default_factory=dict)
+    selected_strategies: List[Dict[str, Any]] = Field(default_factory=list)
+    deployable_bots: List[DeployableBot] = Field(default_factory=list)
+    error: Optional[str] = None
+
+
+class MasterStrategyPipelineController:
+    def __init__(self, db, market_data_service, llm_api_key: Optional[str] = None):
+        self.db = db
+        self.market_data_service = market_data_service
+        self.llm_api_key = llm_api_key
+        self.logs: List[PipelineStageLog] = []
+        self.pipeline_id = str(uuid.uuid4())
+
+    def _log(self, stage: str, success: bool, message: str, **details):
+        icon = "✓" if success else "✗"
+        entry = PipelineStageLog(
+            stage=stage,
+            success=success,
+            message=f"[{icon}] {message}",
+            details=details or {},
+        )
+        self.logs.append(entry)
+
+    async def run(self, request: MasterPipelineRequest) -> MasterPipelineReport:
+        session_id = request.session_id or str(uuid.uuid4())
+
+        try:
+            if not request.prop_rules_confirmed or not request.custom_prop_rules:
+                self._log("custom_prop_rules", False, "Custom prop firm rules are required and must be confirmed")
+                return self._report(
+                    False,
+                    session_id,
+                    request,
+                    error="Pipeline blocked: custom prop firm rules not confirmed.",
+                )
+
+            applied_rules = request.custom_prop_rules or {}
+            if applied_rules.get("max_daily_loss") is not None:
+                request.max_daily_loss_percent = float(applied_rules["max_daily_loss"])
+            if applied_rules.get("max_drawdown") is not None:
+                request.max_portfolio_drawdown_percent = float(applied_rules["max_drawdown"])
+            if applied_rules.get("risk_per_trade") is not None:
+                request.max_position_size_percent = float(applied_rules["risk_per_trade"])
+            trade_limits = applied_rules.get("trade_limits") or {}
+            if trade_limits.get("max_trades_per_day") is not None:
+                request.max_trades_per_day = int(trade_limits["max_trades_per_day"])
+
+            self._log(
+                "custom_prop_rules",
+                True,
+                "Custom prop firm rules applied",
+                confidence=applied_rules.get("confidence"),
+                rules=applied_rules,
+            )
+
+            # Step 1: Real data gate + fetch
+            fetch = await auto_fetch_candles(
+                db=self.db,
+                market_data_service=self.market_data_service,
+                symbol=request.symbol,
+                timeframe=request.timeframe,
+                start_date=request.start_date,
+                end_date=request.end_date,
+                min_candles=request.min_candles,
+            )
+            if not fetch.success:
+                self._log("backtest_data_gate", False, "Real data fetch failed", error=fetch.error)
+                return self._report(False, session_id, request, error=fetch.error)
+
+            candles = fetch.candles
+            self._log(
+                "backtest_data_gate",
+                True,
+                "Real data gate passed",
+                data_source=fetch.source,
+                candle_count=fetch.candle_count,
+                timeframe=request.timeframe,
+                date_range={
+                    "from": request.start_date.isoformat() if request.start_date else None,
+                    "to": request.end_date.isoformat() if request.end_date else None,
+                },
+            )
+
+            # Step 2: Generation + uniqueness filter
+            diversity = create_strategy_diversity_engine()
+            generated = []
+            accepted = []
+            rejected = []
+
+            for tmpl_id in request.templates:
+                template = STRATEGY_TEMPLATES[tmpl_id]
+                batch = StrategyGenerator.generate(template, request.strategies_per_template)
+                generated.extend(batch)
+                expected_total = len(request.templates) * request.strategies_per_template
+
+                for strat in batch:
+                    fp = diversity.build_fingerprint(template, strat.genes, request.timeframe)
+                    decision = diversity.evaluate_uniqueness(
+                        session_id=session_id,
+                        symbol=request.symbol,
+                        fingerprint=fp,
+                        expected_total=expected_total,
+                    )
+                    strat.uniqueness_score = decision.uniqueness_score
+                    strat.diversity_score = decision.diversity_score
+                    strat.uniqueness_status = "accepted" if decision.accepted else "rejected"
+                    strat.strategy_category = decision.strategy_category
+                    strat.rejection_reason = decision.rejection_reason
+                    strat.fingerprint = fp
+                    diversity.register_strategy(
+                        strategy_id=strat.id,
+                        session_id=session_id,
+                        symbol=request.symbol,
+                        timeframe=request.timeframe,
+                        fingerprint=fp,
+                        uniqueness_score=decision.uniqueness_score,
+                        accepted=decision.accepted,
+                        rejection_reason=decision.rejection_reason,
+                    )
+                    if decision.accepted:
+                        accepted.append(strat)
+                    else:
+                        rejected.append(
+                            {
+                                "strategy_id": strat.id,
+                                "template_id": strat.template_id.value,
+                                "reason": decision.rejection_reason,
+                                "uniqueness_score": decision.uniqueness_score,
+                                "diversity_score": decision.diversity_score,
+                                "strategy_category": decision.strategy_category,
+                            }
+                        )
+
+            if not accepted:
+                self._log("uniqueness", False, "No unique strategies passed", rejected=len(rejected))
+                return self._report(
+                    False,
+                    session_id,
+                    request,
+                    generation_summary={"generated": len(generated), "accepted": 0, "rejected": len(rejected)},
+                    error="No unique strategies passed uniqueness filter",
+                )
+
+            self._log(
+                "generation",
+                True,
+                "Generation complete",
+                generated=len(generated),
+            )
+            category_distribution = diversity.get_category_distribution(
+                session_id=session_id,
+                symbol=request.symbol,
+                accepted_only=True,
+            )
+            self._log(
+                "uniqueness",
+                True,
+                "Uniqueness filter passed",
+                generated=len(generated),
+                accepted=len(accepted),
+                rejected=len(rejected),
+                category_distribution=category_distribution,
+            )
+
+            # Step 3/4/5: Backtest + validation + quality filters
+            qualified = []
+            validation_rows = []
+            for strat in accepted:
+                trades, equity_curve, cfg = real_backtester.run(
+                    template_id=strat.template_id.value,
+                    genes=strat.genes,
+                    candles=candles,
+                    initial_balance=request.initial_balance,
+                )
+
+                if not trades:
+                    continue
+
+                metrics = performance_calculator.calculate_metrics(trades, equity_curve, cfg)
+                score = strategy_scorer.calculate_score(metrics)
+
+                mc_config = MonteCarloConfig(
+                    num_simulations=request.monte_carlo_runs,
+                    initial_balance=request.initial_balance,
+                )
+                mc_engine = create_monte_carlo_engine(mc_config, trades)
+                mc_result = mc_engine.run()
+
+                wf_config = self._build_walkforward_config(
+                    strategy=strat,
+                    request=request,
