+"""
+Custom Prop Firm Intelligence System
+Parses uploaded/textual rule documents into a structured JSON policy.
+"""
+
+from __future__ import annotations
+
+import io
+import re
+from dataclasses import dataclass
+from typing import Any, Dict, Optional, Tuple
+
+
+@dataclass
+class PropFirmExtractionResult:
+    rules: Dict[str, Any]
+    confidence: float
+    warnings: list[str]
+    raw_text_length: int
+
+
+class CustomPropFirmIntelligenceEngine:
+    def extract_from_content(
+        self,
+        prop_firm_name: str,
+        website_url: str,
+        text_content: str,
+    ) -> PropFirmExtractionResult:
+        txt = (text_content or "").strip()
+        rules = self._extract_rules(txt)
+        confidence, warnings = self._confidence(rules, txt)
+        rules["prop_firm_name"] = prop_firm_name
+        rules["website_url"] = website_url
+        return PropFirmExtractionResult(
+            rules=rules,
+            confidence=confidence,
+            warnings=warnings,
+            raw_text_length=len(txt),
+        )
+
+    def read_upload_bytes(self, filename: str, content: bytes) -> str:
+        lower = (filename or "").lower()
+        if lower.endswith(".txt"):
+            return content.decode("utf-8", errors="ignore")
+        if lower.endswith(".pdf"):
+            try:
+                from pypdf import PdfReader  # type: ignore
+
+                reader = PdfReader(io.BytesIO(content))
+                return "\n".join((p.extract_text() or "") for p in reader.pages)
+            except Exception:
+                return content.decode("utf-8", errors="ignore")
+        if lower.endswith(".docx"):
+            try:
+                import zipfile
+
+                with zipfile.ZipFile(io.BytesIO(content)) as zf:
+                    xml = zf.read("word/document.xml").decode("utf-8", errors="ignore")
+                    xml = re.sub(r"<[^>]+>", " ", xml)
+                    return re.sub(r"\s+", " ", xml)
+            except Exception:
+                return content.decode("utf-8", errors="ignore")
+        return content.decode("utf-8", errors="ignore")
+
+    def _extract_rules(self, txt: str) -> Dict[str, Any]:
+        lowered = txt.lower()
+        max_daily_loss = self._pct(lowered, [r"max daily loss[^0-9%]{0,20}(\d+(?:\.\d+)?)\s*%"])
+        max_drawdown = self._pct(lowered, [r"max (?:overall |total )?drawdown[^0-9%]{0,20}(\d+(?:\.\d+)?)\s*%"])
+        profit_target = self._pct(lowered, [r"profit target[^0-9%]{0,20}(\d+(?:\.\d+)?)\s*%"])
+        risk_per_trade = self._pct(lowered, [r"risk (?:per trade|/trade)[^0-9%]{0,20}(\d+(?:\.\d+)?)\s*%"])
+        max_trades_per_day = self._int(lowered, [r"max trades per day[^0-9]{0,20}(\d+)"])
+        max_open_trades = self._int(lowered, [r"max open trades?[^0-9]{0,20}(\d+)"])
+
+        restrictions = []
+        for kw in [
+            "no news trading",
+            "weekend holding prohibited",
+            "martingale prohibited",
+            "ea prohibited",
+            "copy trading prohibited",
+            "scalping prohibited",
+        ]:
+            if kw in lowered:
+                restrictions.append(kw)
+
+        return {
+            "max_daily_loss": max_daily_loss,
+            "max_drawdown": max_drawdown,
+            "profit_target": profit_target,
+            "risk_per_trade": risk_per_trade,
+            "trade_limits": {
+                "max_trades_per_day": max_trades_per_day,
+                "max_open_trades": max_open_trades,
+            },
+            "restrictions": restrictions,
+        }
+
+    def _confidence(self, rules: Dict[str, Any], txt: str) -> Tuple[float, list[str]]:
+        score = 0.0
+        warnings = []
+        for key in ["max_daily_loss", "max_drawdown", "profit_target", "risk_per_trade"]:
+            if rules.get(key) is not None:
+                score += 0.2
+        trade_limits = rules.get("trade_limits", {})
+        if trade_limits.get("max_trades_per_day") is not None or trade_limits.get("max_open_trades") is not None:
+            score += 0.1
+        if rules.get("restrictions"):
+            score += 0.1
+        if len(txt) < 100:
+            score -= 0.2
+            warnings.append("Uploaded rules text is very short; extraction may be incomplete.")
+        score = max(0.0, min(1.0, score))
+        if score < 0.65:
+            warnings.append("Low confidence extraction. Please manually review and edit before applying.")
+        return round(score, 3), warnings
+
+    @staticmethod
+    def _pct(text: str, patterns: list[str]) -> Optional[float]:
+        for p in patterns:
+            m = re.search(p, text, flags=re.IGNORECASE)
+            if m:
+                return float(m.group(1))
+        return None
+
+    @staticmethod
+    def _int(text: str, patterns: list[str]) -> Optional[int]:
+        for p in patterns:
+            m = re.search(p, text, flags=re.IGNORECASE)
+            if m:
+                return int(m.group(1))
+        return None
+
