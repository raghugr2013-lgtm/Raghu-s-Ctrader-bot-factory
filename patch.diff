+from __future__ import annotations
+
+from datetime import datetime, timedelta, timezone
+from typing import Any, Dict, List, Optional
+
+
+class CapitalScalingEngine:
+    """Dynamically scale portfolio capital and position sizing from rolling performance."""
+
+    def __init__(
+        self,
+        pf_increase_threshold: float = 1.3,
+        max_capital_scale: float = 1.5,
+        min_capital_scale: float = 0.5,
+        max_step_change: float = 0.1,
+    ):
+        self.pf_increase_threshold = pf_increase_threshold
+        self.max_capital_scale = max_capital_scale
+        self.min_capital_scale = min_capital_scale
+        self.max_step_change = max_step_change
+
+    def evaluate_rolling_performance(self, trades: List[Dict[str, Any]]) -> Dict[str, Any]:
+        now = datetime.now(timezone.utc)
+        metrics_7 = self._window_metrics(trades, now - timedelta(days=7))
+        metrics_30 = self._window_metrics(trades, now - timedelta(days=30))
+        return {"last_7d": metrics_7, "last_30d": metrics_30}
+
+    async def apply_scaling(
+        self,
+        db,
+        pipeline_id: str,
+        risk_summary: Dict[str, Any],
+        performance: Dict[str, Any],
+    ) -> Dict[str, Any]:
+        tier, target_scale = self._target_scale(performance)
+        prev_doc = await db.live_capital_scaling_state.find_one({"pipeline_id": pipeline_id}) or {}
+        prev_scale = float(prev_doc.get("scale_factor", 1.0))
+        scale_factor = self._gradual_scale(prev_scale, target_scale)
+
+        allocations = risk_summary.get("strategy_allocations", [])
+        scaled_allocations = []
+        for item in allocations:
+            scaled = dict(item)
+            scaled["capital_scale_factor"] = round(scale_factor, 4)
+            scaled["risk_tier"] = tier
+            scaled["allocated_capital"] = round(float(item.get("allocated_capital", 0.0)) * scale_factor, 2)
+            scaled["max_position_size_amount"] = round(float(item.get("max_position_size_amount", 0.0)) * scale_factor, 2)
+            scaled_allocations.append(scaled)
+
+        out = dict(risk_summary)
+        out["strategy_allocations"] = scaled_allocations
+        out["capital_scaling"] = {
+            "risk_tier": tier,
+            "scale_factor": round(scale_factor, 4),
+            "target_scale_factor": round(target_scale, 4),
+            "previous_scale_factor": round(prev_scale, 4),
+            "rolling_performance": performance,
+        }
+
+        await db.live_capital_scaling_state.update_one(
+            {"pipeline_id": pipeline_id},
+            {"$set": {
+                "pipeline_id": pipeline_id,
+                "risk_tier": tier,
+                "scale_factor": scale_factor,
+                "target_scale_factor": target_scale,
+                "updated_at": datetime.now(timezone.utc).isoformat(),
+            }},
+            upsert=True,
+        )
+
+        await db.live_retrain_events.insert_one(
+            {
+                "pipeline_id": pipeline_id,
+                "strategy_id": "portfolio",
+                "message": "[✓] Capital scaling adjusted",
+                "detail": f"tier={tier}, scale_factor={scale_factor:.3f}, target={target_scale:.3f}",
+                "timestamp": datetime.now(timezone.utc).isoformat(),
+            }
+        )
+        return out
+
+    def _target_scale(self, performance: Dict[str, Any]) -> (str, float):
+        p7 = performance.get("last_7d", {})
+        p30 = performance.get("last_30d", {})
+        pf7 = float(p7.get("profit_factor", 0.0))
+        pf30 = float(p30.get("profit_factor", 0.0))
+        dd7 = float(p7.get("drawdown_percent", 0.0))
+        dd30 = float(p30.get("drawdown_percent", 0.0))
+
+        if pf30 >= self.pf_increase_threshold and dd30 <= 10.0 and pf7 >= 1.1 and dd7 <= 10.0:
+            return "high_risk", min(self.max_capital_scale, 1.2)
+        if pf30 >= 1.0 and dd30 <= 15.0 and pf7 >= 0.95:
+            return "medium_risk", 1.0
+        return "low_risk", max(self.min_capital_scale, 0.8)
+
+    def _gradual_scale(self, prev_scale: float, target_scale: float) -> float:
+        delta = target_scale - prev_scale
+        if delta > self.max_step_change:
+            return min(self.max_capital_scale, prev_scale + self.max_step_change)
+        if delta < -self.max_step_change:
+            return max(self.min_capital_scale, prev_scale - self.max_step_change)
+        return max(self.min_capital_scale, min(self.max_capital_scale, target_scale))
+
+    @staticmethod
+    def _window_metrics(trades: List[Dict[str, Any]], since: datetime) -> Dict[str, Any]:
+        window = []
+        equity = 0.0
+        peak = 0.0
+        max_dd = 0.0
+        for trade in trades:
+            ts = trade.get("closed_at") or trade.get("timestamp")
+            dt = None
+            if isinstance(ts, str):
+                try:
+                    dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
+                except Exception:
+                    dt = None
+            if dt is None:
+                continue
+            if dt < since:
+                continue
+            pnl = float(trade.get("profit_loss", 0.0))
+            window.append(pnl)
+            equity += pnl
+            peak = max(peak, equity)
+            dd = peak - equity
+            if peak > 0:
+                max_dd = max(max_dd, (dd / peak) * 100.0)
+
+        gross_profit = sum(x for x in window if x > 0)
+        gross_loss = abs(sum(x for x in window if x < 0))
+        pf = gross_profit / gross_loss if gross_loss > 0 else (gross_profit if gross_profit > 0 else 0.0)
+        wins = sum(1 for x in window if x > 0)
+        win_rate = (wins / len(window) * 100.0) if window else 0.0
+        return {
+            "trade_count": len(window),
+            "profit_factor": round(pf, 4),
+            "drawdown_percent": round(max_dd, 4),
+            "win_rate": round(win_rate, 2),
+        }
