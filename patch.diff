+++ b/backend/auto_retrain_engine.py
@@ -0,0 +1,232 @@
+from __future__ import annotations
+
+from datetime import datetime, timezone
+from typing import Any, Dict, List, Optional
+
+from live_monitoring_engine import LivePerformanceMonitoringEngine
+from master_pipeline_controller import MasterPipelineRequest, MasterStrategyPipelineController
+from factory_models import TemplateId
+
+
+class AutoRetrainAndReplacementEngine:
+    """Detect underperformers and replace them via existing master pipeline."""
+
+    def __init__(self, db, market_data_service, llm_api_key: Optional[str] = None):
+        self.db = db
+        self.market_data_service = market_data_service
+        self.llm_api_key = llm_api_key
+        self.monitoring_engine = LivePerformanceMonitoringEngine(db)
+
+    async def run_cycle(
+        self,
+        pipeline_id: str,
+        max_replacements_per_day: int = 2,
+        continuous_loss_trades: int = 4,
+    ) -> Dict[str, Any]:
+        dashboard = await self.monitoring_engine.build_dashboard(pipeline_id)
+        baseline = await self.db.live_pipeline_baselines.find_one({"pipeline_id": pipeline_id}) or {}
+        risk_config = (baseline.get("risk_allocation") or {}).get("risk_config", {})
+        stop_dd = float(risk_config.get("strategy_stop_drawdown_percent", 12.0))
+
+        strategy_stats = dashboard.get("strategy_stats", [])
+        flagged = []
+        for row in strategy_stats:
+            reason = self._underperformance_reason(
+                row=row,
+                stop_drawdown_threshold=stop_dd,
+                continuous_loss_trades=continuous_loss_trades,
+            )
+            if reason:
+                flagged.append({**row, "reason": reason})
+                await self._set_status(pipeline_id, row["strategy_id"], "underperforming", reason)
+                await self._log_event(pipeline_id, row["strategy_id"], "[✓] Strategy flagged as underperforming", reason)
+
+        if not flagged:
+            return {
+                "pipeline_id": pipeline_id,
+                "flagged": [],
+                "replacements": [],
+                "message": "No underperforming strategies detected",
+            }
+
+        replaced_today = await self._replacements_today(pipeline_id)
+        capacity = max(0, max_replacements_per_day - replaced_today)
+        # Safety: avoid replacing all strategies at once.
+        max_batch = max(1, len(strategy_stats) // 2)
+        capacity = min(capacity, max_batch)
+        if capacity <= 0:
+            return {
+                "pipeline_id": pipeline_id,
+                "flagged": flagged,
+                "replacements": [],
+                "message": "Replacement safety limits reached for today",
+            }
+
+        replacements = []
+        for row in flagged[:capacity]:
+            await self._log_event(pipeline_id, row["strategy_id"], "[✓] Retraining triggered", row["reason"])
+            replacement = await self._retrain_one(pipeline_id, row, baseline)
+            if replacement:
+                replacements.append(replacement)
+                await self._set_status(pipeline_id, row["strategy_id"], "disabled", "replaced_by_auto_retrain")
+                await self._set_status(
+                    pipeline_id,
+                    replacement["new_strategy"]["strategy_id"],
+                    "healthy",
+                    "auto_retrain_replacement",
+                )
+                await self._log_event(
+                    pipeline_id,
+                    replacement["new_strategy"]["strategy_id"],
+                    "[✓] Strategy replaced",
+                    f"Replaced {row['strategy_id']}",
+                )
+
+        return {
+            "pipeline_id": pipeline_id,
+            "flagged": flagged,
+            "replacements": replacements,
+            "message": "Auto-retrain cycle completed",
+        }
+
+    @staticmethod
+    def _underperformance_reason(
+        row: Dict[str, Any],
+        stop_drawdown_threshold: float,
+        continuous_loss_trades: int,
+    ) -> Optional[str]:
+        backtest_pf = float(row.get("backtest_profit_factor", 0.0))
+        live_pf = float(row.get("live_profit_factor", 0.0))
+        live_dd = float(row.get("live_drawdown_percent", 0.0))
+        losses = int(row.get("continuous_losses", 0))
+
+        if backtest_pf > 0 and live_pf < backtest_pf * 0.7:
+            return f"Live PF {live_pf:.2f} below 70% of backtest PF {backtest_pf:.2f}"
+        if live_dd > stop_drawdown_threshold:
+            return f"Live drawdown {live_dd:.2f}% above threshold {stop_drawdown_threshold:.2f}%"
+        if losses >= continuous_loss_trades:
+            return f"Continuous losses detected: {losses} trades"
+        return None
+
+    async def _retrain_one(
+        self,
+        pipeline_id: str,
+        strategy_row: Dict[str, Any],
+        baseline_doc: Dict[str, Any],
+    ) -> Optional[Dict[str, Any]]:
+        previous_template = None
+        previous_category = None
+        for base in baseline_doc.get("strategy_baselines", []):
+            if base.get("strategy_id") == strategy_row.get("strategy_id"):
+                previous_template = base.get("template_id")
+                previous_category = base.get("strategy_category")
+                break
+
+        stored_request = baseline_doc.get("pipeline_request", {})
+        templates = list(TemplateId)
+        if previous_template:
+            try:
+                templates = [TemplateId(previous_template)]
+            except Exception:
+                templates = list(TemplateId)
+
+        req = MasterPipelineRequest(
+            session_id=stored_request.get("session_id"),
+            strategy_prompt=stored_request.get("strategy_prompt", "Auto-retrain underperforming strategy."),
+            templates=templates,
+            strategies_per_template=int(stored_request.get("strategies_per_template", 8)),
+            symbol=stored_request.get("symbol", "EURUSD"),
+            timeframe=stored_request.get("timeframe", "1h"),
+            min_candles=int(stored_request.get("min_candles", 2000)),
+            initial_balance=float(stored_request.get("initial_balance", 10000.0)),
+            top_n=max(3, int(stored_request.get("top_n", 5))),
+            ai_model=stored_request.get("ai_model", "openai"),
+            prop_firm=stored_request.get("prop_firm", "ftmo"),
+        )
+
+        controller = MasterStrategyPipelineController(
+            db=self.db,
+            market_data_service=self.market_data_service,
+            llm_api_key=self.llm_api_key,
+        )
+        report = await controller.run(req)
+        if not report.selected_strategies:
+            return None
+
+        preferred = None
+        for candidate in report.selected_strategies:
+            if candidate.get("strategy_category") == previous_category:
+                preferred = candidate
+                break
+        preferred = preferred or report.selected_strategies[0]
+
+        await self._persist_replacement(pipeline_id, strategy_row["strategy_id"], preferred)
+        return {
+            "old_strategy_id": strategy_row["strategy_id"],
+            "new_strategy": preferred,
+            "replacement_pipeline_id": report.pipeline_id,
+        }
+
+    async def _persist_replacement(self, pipeline_id: str, old_strategy_id: str, new_strategy: Dict[str, Any]) -> None:
+        await self.db.live_strategy_controls.insert_one(
+            {
+                "pipeline_id": pipeline_id,
+                "strategy_id": old_strategy_id,
+                "action": "disable",
+                "reason": "auto_retrain_replaced",
+                "timestamp": datetime.now(timezone.utc).isoformat(),
+            }
+        )
+        await self.db.live_strategy_replacements.insert_one(
+            {
+                "pipeline_id": pipeline_id,
+                "old_strategy_id": old_strategy_id,
+                "new_strategy": new_strategy,
+                "timestamp": datetime.now(timezone.utc).isoformat(),
+            }
+        )
+        await self.db.live_pipeline_baselines.update_one(
+            {"pipeline_id": pipeline_id},
+            {"$push": {"strategy_baselines": {
+                "strategy_id": new_strategy.get("strategy_id"),
+                "template_id": new_strategy.get("template_id"),
+                "strategy_category": new_strategy.get("strategy_category"),
+                "backtest_profit_factor": new_strategy.get("profit_factor", 0.0),
+                "backtest_win_rate": new_strategy.get("win_rate", 0.0),
+                "backtest_drawdown_percent": new_strategy.get("max_drawdown_percent", 0.0),
+            }}},
+        )
+        await self.db.live_pipeline_baselines.update_one(
+            {"pipeline_id": pipeline_id},
+            {"$pull": {"strategy_baselines": {"strategy_id": old_strategy_id}}},
+        )
+
+    async def _set_status(self, pipeline_id: str, strategy_id: str, status: str, reason: str) -> None:
+        await self.db.live_strategy_status.update_one(
+            {"pipeline_id": pipeline_id, "strategy_id": strategy_id},
+            {"$set": {
+                "pipeline_id": pipeline_id,
+                "strategy_id": strategy_id,
+                "status": status,  # healthy | underperforming | disabled
+                "reason": reason,
+                "updated_at": datetime.now(timezone.utc).isoformat(),
+            }},
+            upsert=True,
+        )
+
+    async def _log_event(self, pipeline_id: str, strategy_id: str, message: str, detail: str) -> None:
+        await self.db.live_retrain_events.insert_one(
+            {
+                "pipeline_id": pipeline_id,
+                "strategy_id": strategy_id,
+                "message": message,
+                "detail": detail,
+                "timestamp": datetime.now(timezone.utc).isoformat(),
+            }
+        )
+
+    async def _replacements_today(self, pipeline_id: str) -> int:
+        today = datetime.now(timezone.utc).date().isoformat()
+        return await self.db.live_strategy_replacements.count_documents(
+            {"pipeline_id": pipeline_id, "timestamp": {"$regex": f"^{today}"}}
+        )
