+def _load_local_candles(
+    symbol: str,
+    timeframe: str,
+    start_date: datetime,
+    end_date: datetime,
+) -> List[Candle]:
+    """Load candles from /app/data/{symbol}/{timeframe}/ CSV files if available."""
+    root = f"/app/data/{symbol.upper()}/{timeframe.lower()}"
+    if not os.path.isdir(root):
+        return []
+
+    try:
+        tf_enum = DataTimeframe(timeframe.lower())
+    except ValueError:
+        return []
+
+    candles: List[Candle] = []
+    csv_files = sorted([f for f in os.listdir(root) if f.lower().endswith(".csv")])
+    for fname in csv_files:
+        path = os.path.join(root, fname)
+        with open(path, "r", encoding="utf-8") as f:
+            reader = csv.DictReader(f)
+            for row in reader:
+                ts = _parse_timestamp(row.get("timestamp") or row.get("time") or row.get("datetime"))
+                if ts is None:
+                    continue
+                if ts < start_date or ts > end_date:
+                    continue
+                try:
+                    candles.append(
+                        Candle(
+                            timestamp=ts,
+                            open=float(row.get("open")),
+                            high=float(row.get("high")),
+                            low=float(row.get("low")),
+                            close=float(row.get("close")),
+                            volume=float(row.get("volume", 0.0) or 0.0),
+                            symbol=symbol,
+                            timeframe=tf_enum,
+                        )
+                    )
+                except Exception:
+                    continue
+
+    candles.sort(key=lambda c: c.timestamp)
+    return candles
+
+
+def _parse_timestamp(raw: Optional[str]) -> Optional[datetime]:
+    if not raw:
+        return None
+    txt = str(raw).strip()
+    try:
+        return datetime.fromisoformat(txt.replace("Z", "+00:00"))
+    except Exception:
+        pass
+    for fmt in ("%Y-%m-%d %H:%M:%S", "%Y-%m-%d"):
+        try:
+            dt = datetime.strptime(txt, fmt)
+            return dt.replace(tzinfo=timezone.utc)
+        except Exception:
+            continue
+    return None
+
