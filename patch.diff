+#!/usr/bin/env bash
+set -euo pipefail
+
+PREVIEW_URL="${1:-https://algo-bot-validator.preview.emergentagent.com}"
+EXPECTED="v2.2-pipeline"
+
+echo "==> Building frontend"
+pushd frontend >/dev/null
+npm ci
+npm run build
+popd >/dev/null
+
+echo "==> Checking deployed preview markers"
+echo "URL: ${PREVIEW_URL}"
+
+INDEX="$(curl -fsSL "${PREVIEW_URL}/" || true)"
+VERSION_HTML="$(curl -fsSL "${PREVIEW_URL}/version.html" || true)"
+VERSION_JSON="$(curl -fsSL "${PREVIEW_URL}/version.json" || true)"
+VERSION_TXT="$(curl -fsSL "${PREVIEW_URL}/version.txt" || true)"
+
+echo "---- index marker ----"
+echo "${INDEX}" | grep -Eo 'build-version" content="[^"]+' || true
+echo "---- version.html marker ----"
+echo "${VERSION_HTML}" | grep -Eo 'v2\\.[^<]+' | head -n 1 || true
+echo "---- version.json marker ----"
+echo "${VERSION_JSON}" | grep -Eo '"build_version":\\s*"[^"]+' || true
+echo "---- version.txt marker ----"
+echo "${VERSION_TXT}" | head -n 1 || true
+
+if echo "${VERSION_HTML}${VERSION_JSON}${VERSION_TXT}${INDEX}" | grep -q "${EXPECTED}"; then
+  echo "✅ Deployment marker detected: ${EXPECTED}"
+else
+  echo "❌ Expected marker ${EXPECTED} not found in preview output"
+  exit 1
+fi
