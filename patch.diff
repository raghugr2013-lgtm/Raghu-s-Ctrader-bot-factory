+from __future__ import annotations
+
+from typing import Any, Dict, List
+
+from regime_engine import RegimeClassifier
+from regime_models import MarketRegime
+
+
+class MarketRegimeAdaptationEngine:
+    """Detect current market regime and bias strategy selection toward matching archetypes."""
+
+    TEMPLATE_TAGS = {
+        "ema_crossover": "trend",
+        "macd_trend": "trend",
+        "rsi_mean_reversion": "mean_reversion",
+        "bollinger_breakout": "breakout",
+        "atr_volatility_breakout": "volatility",
+    }
+
+    REGIME_MATCH = {
+        "trending": {"trend": 1.0, "breakout": 0.7, "volatility": 0.6, "mean_reversion": 0.2},
+        "ranging": {"mean_reversion": 1.0, "trend": 0.3, "breakout": 0.4, "volatility": 0.5},
+        "high_volatility": {"volatility": 1.0, "breakout": 0.9, "trend": 0.5, "mean_reversion": 0.3},
+    }
+
+    def detect_regime(self, candles: List[Any]) -> Dict[str, Any]:
+        if not candles or len(candles) < 60:
+            return {
+                "regime": "ranging",
+                "raw_regime": MarketRegime.RANGING.value,
+                "adx": 0.0,
+                "atr_pct": 0.0,
+            }
+
+        timestamps = [c.timestamp.isoformat() if hasattr(c.timestamp, "isoformat") else str(c.timestamp) for c in candles]
+        opens = [float(c.open) for c in candles]
+        highs = [float(c.high) for c in candles]
+        lows = [float(c.low) for c in candles]
+        closes = [float(c.close) for c in candles]
+        volumes = [float(getattr(c, "volume", 0.0) or 0.0) for c in candles]
+
+        classifier = RegimeClassifier()
+        labelled = classifier.classify(timestamps, opens, highs, lows, closes, volumes)
+        latest = labelled[-1]
+        bucket = self._bucket(latest.regime)
+        return {
+            "regime": bucket,
+            "raw_regime": latest.regime.value,
+            "adx": latest.adx,
+            "atr_pct": latest.atr_pct,
+        }
+
+    def adjust_candidates(
+        self,
+        candidates: List[Dict[str, Any]],
+        detected_regime: str,
+    ) -> List[Dict[str, Any]]:
+        adjusted = []
+        for row in candidates:
+            strategy = row["strategy"]
+            template_id = strategy.template_id.value
+            tag = self.TEMPLATE_TAGS.get(template_id, "trend")
+            fit = self.REGIME_MATCH.get(detected_regime, {}).get(tag, 0.5)
+
+            row["regime_tag"] = tag
+            row["regime_fit_score"] = fit
+            adjusted.append(row)
+
+        adjusted.sort(
+            key=lambda r: (
+                r.get("regime_fit_score", 0.5),
+                r["score"].total_score,
+                r["metrics"].profit_factor,
+                -r["metrics"].max_drawdown_percent,
+            ),
+            reverse=True,
+        )
+        return adjusted
+
+    @staticmethod
+    def _bucket(raw_regime: MarketRegime) -> str:
+        if raw_regime in (MarketRegime.TRENDING_UP, MarketRegime.TRENDING_DOWN):
+            return "trending"
+        if raw_regime == MarketRegime.HIGH_VOLATILITY:
+            return "high_volatility"
+        return "ranging"
