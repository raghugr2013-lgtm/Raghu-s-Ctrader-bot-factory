+                    "risk_allocation": risk_allocation or {},
+                    "pipeline_request": pipeline_request or {},
+                    "updated_at": datetime.now(timezone.utc).isoformat(),
+                }
+            },
+            upsert=True,
+        )
+
+    async def ingest_trade(self, trade: Dict[str, Any]) -> Dict[str, Any]:
+        trade_doc = {
+            "pipeline_id": trade["pipeline_id"],
+            "strategy_id": trade["strategy_id"],
+            "symbol": trade.get("symbol", "EURUSD"),
+            "profit_loss": float(trade.get("profit_loss", 0.0)),
+            "status": trade.get("status", "closed"),
+            "opened_at": trade.get("opened_at") or datetime.now(timezone.utc).isoformat(),
+            "closed_at": trade.get("closed_at") or datetime.now(timezone.utc).isoformat(),
+            "metadata": trade.get("metadata", {}),
+            "timestamp": datetime.now(timezone.utc).isoformat(),
+        }
+        await self.db.live_trades.insert_one(trade_doc)
+        return trade_doc
+
+    async def build_dashboard(self, pipeline_id: str) -> Dict[str, Any]:
+        baseline = await self.db.live_pipeline_baselines.find_one({"pipeline_id": pipeline_id}) or {}
+        cursor = self.db.live_trades.find({"pipeline_id": pipeline_id, "status": "closed"})
+        trades = await cursor.to_list(length=20000)
+        status_docs = await self.db.live_strategy_status.find({"pipeline_id": pipeline_id}).to_list(length=1000)
+        status_map = {row.get("strategy_id"): row for row in status_docs}
+
+        per_strategy: Dict[str, Dict[str, Any]] = {}
+        combined_balance = 0.0
+        gross_profit = 0.0
+        gross_loss = 0.0
+        wins = 0
+        day_pnl: Dict[str, float] = {}
+        trades_by_strategy: Dict[str, List[Dict[str, Any]]] = {}
+
+        for trade in trades:
+            sid = trade["strategy_id"]
+            pnl = float(trade.get("profit_loss", 0.0))
+            closed_at = trade.get("closed_at") or trade.get("timestamp")
+            day_key = str(closed_at)[:10]
+
+            combined_balance += pnl
+            gross_profit += pnl if pnl > 0 else 0.0
+            gross_loss += abs(pnl) if pnl < 0 else 0.0
+            if pnl > 0:
+                wins += 1
+
+            day_pnl[day_key] = day_pnl.get(day_key, 0.0) + pnl
+            trades_by_strategy.setdefault(sid, []).append(trade)
+
+            row = per_strategy.setdefault(
+                sid,
+                {
+                    "strategy_id": sid,
+                    "total_trades": 0,
+                    "wins": 0,
+                    "net_profit": 0.0,
+                    "gross_profit": 0.0,
+                    "gross_loss": 0.0,
+                    "equity": 0.0,
+                    "peak_equity": 0.0,
+                    "max_drawdown_percent": 0.0,
+                },
+            )
+
+            row["total_trades"] += 1
+            if pnl > 0:
+                row["wins"] += 1
+                row["gross_profit"] += pnl
+            elif pnl < 0:
+                row["gross_loss"] += abs(pnl)
+
+            row["net_profit"] += pnl
+            row["equity"] += pnl
+            row["peak_equity"] = max(row["peak_equity"], row["equity"])
+            peak = max(row["peak_equity"], 1e-9)
+            dd_pct = ((peak - row["equity"]) / peak) * 100.0
+            row["max_drawdown_percent"] = max(row["max_drawdown_percent"], dd_pct)
+
+        strategy_baselines = {
+            item.get("strategy_id"): item
+            for item in baseline.get("strategy_baselines", [])
+            if item.get("strategy_id")
+        }
+
+        strategy_rows = []
+        for sid, row in per_strategy.items():
+            total = row["total_trades"]
+            win_rate = (row["wins"] / total * 100.0) if total else 0.0
+            pf = (
+                row["gross_profit"] / row["gross_loss"]
+                if row["gross_loss"] > 0
+                else (row["gross_profit"] if row["gross_profit"] > 0 else 0.0)
+            )
+            baseline_row = strategy_baselines.get(sid, {})
+            strategy_rows.append(
+                {
+                    "strategy_id": sid,
+                    "total_trades": total,
+                    "live_net_profit": round(row["net_profit"], 2),
+                    "live_win_rate": round(win_rate, 2),
+                    "live_profit_factor": round(pf, 4),
+                    "live_drawdown_percent": round(row["max_drawdown_percent"], 4),
+                    "backtest_win_rate": baseline_row.get("backtest_win_rate", 0.0),
+                    "backtest_profit_factor": baseline_row.get("backtest_profit_factor", 0.0),
+                    "backtest_drawdown_percent": baseline_row.get("backtest_drawdown_percent", 0.0),
+                    "continuous_losses": self._continuous_losses(trades_by_strategy.get(sid, [])),
+                    "status": (status_map.get(sid) or {}).get("status", "healthy"),
+                }
+            )
+
+        strategy_rows.sort(key=lambda x: x["live_net_profit"], reverse=True)
+        best_strategy = strategy_rows[0] if strategy_rows else None
+        worst_strategy = strategy_rows[-1] if strategy_rows else None
+
+        total_trades = len(trades)
+        portfolio_win_rate = (wins / total_trades * 100.0) if total_trades else 0.0
+        portfolio_pf = gross_profit / gross_loss if gross_loss > 0 else (gross_profit if gross_profit > 0 else 0.0)
+        worst_day_pnl = min(day_pnl.values()) if day_pnl else 0.0
+
+        alerts = self._build_alerts(
+            strategy_rows=strategy_rows,
+            risk_config=(baseline.get("risk_allocation") or {}).get("risk_config", {}),
+            worst_day_pnl=worst_day_pnl,
+        )
+
+        return {
+            "pipeline_id": pipeline_id,
+            "updated_at": datetime.now(timezone.utc).isoformat(),
+            "strategy_stats": strategy_rows,
+            "best_strategy": best_strategy,
+            "worst_strategy": worst_strategy,
+            "portfolio": {
+                "net_profit": round(combined_balance, 2),
+                "total_trades": total_trades,
+                "win_rate": round(portfolio_win_rate, 2),
+                "profit_factor": round(portfolio_pf, 4),
+                "daily_performance": [{"day": day, "pnl": round(pnl, 2)} for day, pnl in sorted(day_pnl.items())],
+            },
+            "alerts": alerts,
+            "health": "critical" if any(a["severity"] == "critical" for a in alerts) else "healthy",
+        }
+
+    @staticmethod
+    def _continuous_losses(trades: List[Dict[str, Any]]) -> int:
+        if not trades:
+            return 0
+        ordered = sorted(trades, key=lambda t: str(t.get("closed_at") or t.get("timestamp")))
+        streak = 0
+        for trade in reversed(ordered):
+            pnl = float(trade.get("profit_loss", 0.0))
+            if pnl < 0:
+                streak += 1
+            else:
+                break
+        return streak
+
+    def _build_alerts(
+        self,
+        strategy_rows: List[Dict[str, Any]],
+        risk_config: Dict[str, Any],
+        worst_day_pnl: float,
+    ) -> List[Dict[str, Any]]:
+        alerts: List[Dict[str, Any]] = []
+        max_daily_loss_pct = float(risk_config.get("max_daily_loss_percent", 5.0))
+        stop_dd = float(risk_config.get("strategy_stop_drawdown_percent", 12.0))
+
+        # Base denominator assumes baseline 10k if precise account not supplied.
+        day_loss_pct = abs(min(worst_day_pnl, 0.0)) / 10000.0 * 100.0
+        if day_loss_pct > max_daily_loss_pct:
+            alerts.append(
+                {
+                    "type": "daily_loss_breach",
+                    "severity": "critical",
+                    "message": f"Daily loss breach: {day_loss_pct:.2f}% > {max_daily_loss_pct:.2f}%",
+                }
+            )
+
+        for row in strategy_rows:
+            if row["live_drawdown_percent"] > stop_dd:
+                alerts.append(
+                    {
+                        "type": "strategy_failure",
+                        "severity": "critical",
+                        "strategy_id": row["strategy_id"],
+                        "message": (
+                            f"Strategy {row['strategy_id']} drawdown {row['live_drawdown_percent']:.2f}% "
+                            f"exceeds stop threshold {stop_dd:.2f}%."
+                        ),
+                        "action": "disable_or_replace",
+                    }
+                )
+            if row["live_profit_factor"] < max(0.7, row["backtest_profit_factor"] * 0.5):
+                alerts.append(
+                    {
+                        "type": "underperformance",
+                        "severity": "warning",
+                        "strategy_id": row["strategy_id"],
+                        "message": (
+                            f"Strategy {row['strategy_id']} live PF {row['live_profit_factor']:.2f} is materially "
+                            "below backtest expectation."
+                        ),
+                        "action": "review_and_replace_candidate",
+                    }
+                )
+
+        return alerts
