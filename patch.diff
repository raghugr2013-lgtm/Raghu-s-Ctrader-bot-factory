+++ b/backend/risk_allocation_engine.py
@@ -0,0 +1,177 @@
+from __future__ import annotations
+
+from datetime import datetime
+from statistics import stdev
+from typing import Any, Dict, List, Tuple
+
+from backtest_models import TradeStatus
+
+
+class RiskAndCapitalAllocationEngine:
+    """Allocate capital and attach risk controls for selected portfolio strategies."""
+
+    def __init__(
+        self,
+        allocation_method: str = "risk_adjusted",
+        max_portfolio_drawdown_percent: float = 20.0,
+        max_daily_loss_percent: float = 5.0,
+        max_trades_per_day: int = 15,
+        max_position_size_percent: float = 2.0,
+        strategy_stop_drawdown_percent: float = 12.0,
+    ):
+        self.allocation_method = allocation_method
+        self.max_portfolio_drawdown_percent = max_portfolio_drawdown_percent
+        self.max_daily_loss_percent = max_daily_loss_percent
+        self.max_trades_per_day = max_trades_per_day
+        self.max_position_size_percent = max_position_size_percent
+        self.strategy_stop_drawdown_percent = strategy_stop_drawdown_percent
+
+    def build(
+        self,
+        selected_rows: List[Dict[str, Any]],
+        initial_balance: float,
+    ) -> Dict[str, Any]:
+        if not selected_rows:
+            return {
+                "allocation_method": self.allocation_method,
+                "strategy_allocations": [],
+                "risk_config": self._risk_config(),
+                "portfolio_limits": self._portfolio_limits(initial_balance),
+                "portfolio_monitoring": self._empty_monitoring(),
+            }
+
+        weights = self._compute_weights(selected_rows)
+        strategy_allocations = []
+        for row, weight in zip(selected_rows, weights):
+            strategy = row["strategy"]
+            allocated_capital = initial_balance * weight
+            max_position_size_amount = allocated_capital * (self.max_position_size_percent / 100.0)
+            strategy_allocations.append(
+                {
+                    "strategy_id": strategy.id,
+                    "template_id": strategy.template_id.value,
+                    "strategy_category": strategy.strategy_category,
+                    "weight": round(weight, 6),
+                    "allocated_capital": round(allocated_capital, 2),
+                    "max_position_size_percent": self.max_position_size_percent,
+                    "max_position_size_amount": round(max_position_size_amount, 2),
+                    "stop_trading_drawdown_percent": self.strategy_stop_drawdown_percent,
+                }
+            )
+
+        monitoring = self._build_monitoring(selected_rows, initial_balance, strategy_allocations)
+
+        return {
+            "allocation_method": self.allocation_method,
+            "strategy_allocations": strategy_allocations,
+            "risk_config": self._risk_config(),
+            "portfolio_limits": self._portfolio_limits(initial_balance),
+            "portfolio_monitoring": monitoring,
+        }
+
+    def _compute_weights(self, rows: List[Dict[str, Any]]) -> List[float]:
+        n = len(rows)
+        if n == 0:
+            return []
+
+        if self.allocation_method == "equal_weight":
+            return [1.0 / n for _ in rows]
+
+        raw_scores: List[float] = []
+        for row in rows:
+            returns = row.get("returns", [])
+            volatility = stdev(returns) if len(returns) > 1 else 0.0
+            drawdown = max(row["metrics"].max_drawdown_percent, 0.01)
+
+            dd_component = 1.0 / drawdown
+            vol_component = 1.0 / max(volatility, 1e-6)
+            score = dd_component * 0.6 + vol_component * 0.4
+            raw_scores.append(max(score, 1e-6))
+
+        total = sum(raw_scores)
+        return [score / total for score in raw_scores]
+
+    def _build_monitoring(
+        self,
+        rows: List[Dict[str, Any]],
+        initial_balance: float,
+        allocations: List[Dict[str, Any]],
+    ) -> Dict[str, Any]:
+        stream: List[Tuple[datetime, float]] = []
+        weight_by_strategy = {item["strategy_id"]: item["weight"] for item in allocations}
+
+        for row in rows:
+            strategy_id = row["strategy"].id
+            weight = weight_by_strategy.get(strategy_id, 0.0)
+            for trade in row.get("trades", []):
+                if trade.status != TradeStatus.CLOSED or trade.profit_loss is None:
+                    continue
+                stream.append((trade.exit_time or trade.entry_time, float(trade.profit_loss) * weight))
+
+        if not stream:
+            return self._empty_monitoring()
+
+        stream.sort(key=lambda point: point[0])
+        balance = initial_balance
+        peak = initial_balance
+        max_dd = 0.0
+        equity_curve = []
+        day_pnl: Dict[str, float] = {}
+        day_trades: Dict[str, int] = {}
+
+        for ts, pnl in stream:
+            balance += pnl
+            if balance > peak:
+                peak = balance
+            dd_pct = ((peak - balance) / peak * 100.0) if peak > 0 else 0.0
+            max_dd = max(max_dd, dd_pct)
+            equity_curve.append(
+                {
+                    "timestamp": ts.isoformat(),
+                    "balance": round(balance, 2),
+                    "drawdown_percent": round(dd_pct, 4),
+                }
+            )
+            day_key = ts.date().isoformat()
+            day_pnl[day_key] = day_pnl.get(day_key, 0.0) + pnl
+            day_trades[day_key] = day_trades.get(day_key, 0) + 1
+
+        worst_day_loss_pct = 0.0
+        for pnl in day_pnl.values():
+            day_loss_pct = abs(min(0.0, pnl)) / initial_balance * 100.0 if initial_balance > 0 else 0.0
+            worst_day_loss_pct = max(worst_day_loss_pct, day_loss_pct)
+
+        peak_day_trades = max(day_trades.values()) if day_trades else 0
+
+        return {
+            "combined_equity_curve": equity_curve,
+            "live_drawdown_percent": round(max_dd, 4),
+            "worst_day_loss_percent": round(worst_day_loss_pct, 4),
+            "peak_trades_per_day": peak_day_trades,
+        }
+
+    def _risk_config(self) -> Dict[str, Any]:
+        return {
+            "max_portfolio_drawdown_percent": self.max_portfolio_drawdown_percent,
+            "max_daily_loss_percent": self.max_daily_loss_percent,
+            "max_trades_per_day": self.max_trades_per_day,
+            "max_position_size_percent": self.max_position_size_percent,
+            "strategy_stop_drawdown_percent": self.strategy_stop_drawdown_percent,
+        }
+
+    def _portfolio_limits(self, initial_balance: float) -> Dict[str, Any]:
+        return {
+            "max_portfolio_drawdown_percent": self.max_portfolio_drawdown_percent,
+            "max_daily_loss_percent": self.max_daily_loss_percent,
+            "max_daily_loss_amount": round(initial_balance * (self.max_daily_loss_percent / 100.0), 2),
+            "max_trades_per_day": self.max_trades_per_day,
+        }
+
+    @staticmethod
+    def _empty_monitoring() -> Dict[str, Any]:
+        return {
+            "combined_equity_curve": [],
+            "live_drawdown_percent": 0.0,
+            "worst_day_loss_percent": 0.0,
+            "peak_trades_per_day": 0,
+        }
