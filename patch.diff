+from __future__ import annotations
+
+from datetime import datetime
+from typing import Any, Dict, List, Tuple
+
+from backtest_models import TradeStatus
+from strategy_correlation_engine import StrategyCorrelationEngine
+
+
+class PortfolioSelectionEngine:
+    """Greedy portfolio selection over validated, correlation-filtered strategies."""
+
+    def __init__(
+        self,
+        min_size: int = 3,
+        max_size: int = 5,
+        correlation_threshold: float = 0.8,
+    ):
+        self.min_size = min_size
+        self.max_size = max_size
+        self.correlation_threshold = correlation_threshold
+        self.correlation_engine = StrategyCorrelationEngine(threshold=correlation_threshold)
+
+    def select(self, candidates: List[Dict[str, Any]], initial_balance: float) -> Dict[str, Any]:
+        if not candidates:
+            return {
+                "selected_rows": [],
+                "portfolio_metrics": self._empty_metrics(initial_balance),
+            }
+
+        ordered = sorted(
+            candidates,
+            key=lambda row: (
+                row["metrics"].profit_factor,
+                -row["metrics"].max_drawdown_percent,
+                row["metrics"].win_rate,
+                row["score"].total_score,
+            ),
+            reverse=True,
+        )
+
+        selected: List[Dict[str, Any]] = [ordered[0]]
+        remaining = ordered[1:]
+
+        while remaining and len(selected) < self.max_size:
+            best_candidate = None
+            best_value = float("-inf")
+            must_fill_min = len(selected) < min(self.min_size, len(ordered))
+
+            for candidate in remaining:
+                if self._violates_correlation(candidate, selected):
+                    continue
+
+                trial = selected + [candidate]
+                metrics = self._combine_performance(trial, initial_balance)
+                objective_value = self._objective(metrics, trial)
+
+                # Before min size, accept best valid improvement even if objective is weaker.
+                if must_fill_min:
+                    if objective_value > best_value:
+                        best_value = objective_value
+                        best_candidate = candidate
+                    continue
+
+                baseline = self._combine_performance(selected, initial_balance)
+                baseline_value = self._objective(baseline, selected)
+                improvement = objective_value - baseline_value
+                if improvement > best_value:
+                    best_value = improvement
+                    best_candidate = candidate
+
+            if best_candidate is None:
+                break
+
+            selected.append(best_candidate)
+            remaining = [row for row in remaining if row["strategy"].id != best_candidate["strategy"].id]
+
+        metrics = self._combine_performance(selected, initial_balance)
+        return {
+            "selected_rows": selected,
+            "portfolio_metrics": metrics,
+        }
+
+    def _violates_correlation(self, candidate: Dict[str, Any], selected: List[Dict[str, Any]]) -> bool:
+        candidate_returns = candidate.get("returns", [])
+        for row in selected:
+            corr = self.correlation_engine.pearson_correlation(
+                candidate_returns,
+                row.get("returns", []),
+            )
+            if corr > self.correlation_threshold:
+                return True
+        return False
+
+    def _objective(self, metrics: Dict[str, Any], selected_rows: List[Dict[str, Any]]) -> float:
+        categories = {row["strategy"].strategy_category for row in selected_rows}
+        avg_corr = self._average_pairwise_corr(selected_rows)
+        diversity_bonus = len(categories) * 6.0
+        return (
+            metrics["combined_profit_factor"] * 35.0
+            - metrics["combined_drawdown_percent"] * 1.5
+            + metrics["combined_win_rate"] * 0.5
+            + diversity_bonus
+            - max(0.0, avg_corr) * 10.0
+        )
+
+    def _average_pairwise_corr(self, rows: List[Dict[str, Any]]) -> float:
+        if len(rows) < 2:
+            return 0.0
+        corrs: List[float] = []
+        for i in range(len(rows)):
+            for j in range(i + 1, len(rows)):
+                corrs.append(
+                    self.correlation_engine.pearson_correlation(
+                        rows[i].get("returns", []),
+                        rows[j].get("returns", []),
+                    )
+                )
+        return sum(corrs) / len(corrs) if corrs else 0.0
+
+    def _combine_performance(self, rows: List[Dict[str, Any]], initial_balance: float) -> Dict[str, Any]:
+        if not rows:
+            return self._empty_metrics(initial_balance)
+
+        weight = 1.0 / len(rows)
+        stream: List[Tuple[datetime, float]] = []
+
+        for row in rows:
+            for trade in row.get("trades", []):
+                if trade.status != TradeStatus.CLOSED or trade.profit_loss is None:
+                    continue
+                timestamp = trade.exit_time or trade.entry_time
+                stream.append((timestamp, float(trade.profit_loss) * weight))
+
+        if not stream:
+            return self._empty_metrics(initial_balance)
+
+        stream.sort(key=lambda point: point[0])
+
+        balance = initial_balance
+        peak = initial_balance
+        max_drawdown_pct = 0.0
+        gross_profit = 0.0
+        gross_loss = 0.0
+        wins = 0
+
+        for _, pnl in stream:
+            balance += pnl
+            if pnl > 0:
+                gross_profit += pnl
+                wins += 1
+            elif pnl < 0:
+                gross_loss += abs(pnl)
+
+            if balance > peak:
+                peak = balance
+            if peak > 0:
+                dd_pct = ((peak - balance) / peak) * 100.0
+                max_drawdown_pct = max(max_drawdown_pct, dd_pct)
+
+        total_trades = len(stream)
+        win_rate = (wins / total_trades) * 100.0 if total_trades else 0.0
+        profit_factor = gross_profit / gross_loss if gross_loss > 0 else (gross_profit if gross_profit > 0 else 0.0)
+
+        return {
+            "combined_profit_factor": round(profit_factor, 4),
+            "combined_drawdown_percent": round(max_drawdown_pct, 4),
+            "combined_win_rate": round(win_rate, 4),
+            "total_portfolio_trades": total_trades,
+            "portfolio_size": len(rows),
+        }
+
+    @staticmethod
+    def _empty_metrics(initial_balance: float) -> Dict[str, Any]:
+        return {
+            "combined_profit_factor": 0.0,
+            "combined_drawdown_percent": 0.0,
+            "combined_win_rate": 0.0,
+            "total_portfolio_trades": 0,
+            "portfolio_size": 0,
+            "initial_balance": initial_balance,
+        }
