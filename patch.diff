+echo "  ${BASE_URL}/?build=${BUILD_ID}"
+echo "  ${BASE_URL}/version.html?build=${BUILD_ID}"
+echo "  ${BASE_URL}/version.json?build=${BUILD_ID}"
+echo "  ${BASE_URL}/version.txt?build=${BUILD_ID}"
