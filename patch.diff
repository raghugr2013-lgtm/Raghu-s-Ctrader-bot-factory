+Strategy Uniqueness & Diversity Engine
+Provides:
+1. Strategy fingerprinting
+2. Uniqueness scoring (0-100)
+3. Duplicate/similarity rejection
+4. Strategy registry persistence
+5. Correlation placeholder fields for future portfolio construction
+"""
+
+from __future__ import annotations
+
+import os
+import logging
+from dataclasses import dataclass
+from datetime import datetime, timezone
+from typing import Any, Dict, List, Optional, Tuple
+
+from pymongo import MongoClient
+
+from factory_models import StrategyTemplate, TemplateId
+
+logger = logging.getLogger(__name__)
+
+
+TEMPLATE_INDICATORS = {
+    TemplateId.EMA_CROSSOVER: ["ema", "atr", "adx"],
+    TemplateId.RSI_MEAN_REVERSION: ["rsi", "bollinger_bands"],
+    TemplateId.MACD_TREND: ["macd", "ema", "atr", "adx"],
+    TemplateId.BOLLINGER_BREAKOUT: ["bollinger_bands", "atr", "adx"],
+    TemplateId.ATR_VOLATILITY_BREAKOUT: ["atr", "ema", "adx"],
+}
+
+ENTRY_LOGIC_MAP = {
+    TemplateId.EMA_CROSSOVER: "trend",
+    TemplateId.RSI_MEAN_REVERSION: "mean_reversion",
+    TemplateId.MACD_TREND: "trend",
+    TemplateId.BOLLINGER_BREAKOUT: "breakout",
+    TemplateId.ATR_VOLATILITY_BREAKOUT: "volatility",
+}
+
+EXIT_LOGIC_MAP = {
+    TemplateId.EMA_CROSSOVER: "atr_sl_tp",
+    TemplateId.RSI_MEAN_REVERSION: "bb_rsi_revert",
+    TemplateId.MACD_TREND: "atr_sl_tp",
+    TemplateId.BOLLINGER_BREAKOUT: "atr_breakout_exit",
+    TemplateId.ATR_VOLATILITY_BREAKOUT: "atr_volatility_exit",
+}
+
+
+@dataclass
+class UniquenessDecision:
+    uniqueness_score: float
+    diversity_score: float
+    max_similarity: float
+    accepted: bool
+    rejection_reason: Optional[str]
+    closest_strategy_id: Optional[str]
+    strategy_category: str
+    category_distribution: Dict[str, int]
+    fingerprint: Dict[str, Any]
+
+
+class StrategyDiversityEngine:
+    """Computes uniqueness scores and manages strategy registry."""
+
+    def __init__(
+        self,
+        similarity_reject_threshold: float = 0.85,
+        duplicate_reject_threshold: float = 0.95,
+    ):
+        self.similarity_reject_threshold = similarity_reject_threshold
+        self.duplicate_reject_threshold = duplicate_reject_threshold
+        self._in_memory_registry: List[Dict[str, Any]] = []
+        self._mongo_enabled = bool(os.environ.get("MONGO_URL") and os.environ.get("DB_NAME"))
+        self._registry_collection = "strategy_registry"
+
+    def build_fingerprint(
+        self,
+        template: StrategyTemplate,
+        genes: Dict[str, float],
+        timeframe: str,
+    ) -> Dict[str, Any]:
+        """Create normalized strategy fingerprint."""
+        param_signature = {}
+        for p in template.param_definitions:
+            raw = float(genes.get(p.name, (p.min_val + p.max_val) / 2))
+            clamped = max(float(p.min_val), min(float(p.max_val), raw))
+            span = float(p.max_val - p.min_val) if p.max_val != p.min_val else 1.0
+            normalized = (clamped - float(p.min_val)) / span
+            param_signature[p.name] = round(normalized, 4)
+
+        return {
+            "template_id": template.id.value,
+            "indicators": TEMPLATE_INDICATORS.get(template.id, []),
+            "parameters": param_signature,
+            "timeframe": timeframe.lower(),
+            "entry_logic_type": ENTRY_LOGIC_MAP.get(template.id, template.backtest_strategy_type),
+            "exit_logic_type": EXIT_LOGIC_MAP.get(template.id, "default_exit"),
+            "correlation_features": {
+                "equity_curve_signature": None,
+                "pnl_distribution_signature": None,
+            },
+        }
+
+    def evaluate_uniqueness(
+        self,
+        session_id: str,
+        symbol: str,
+        fingerprint: Dict[str, Any],
+        expected_total: Optional[int] = None,
+    ) -> UniquenessDecision:
+        """Compare candidate fingerprint against registry and produce uniqueness score."""
+        existing = self._load_registry(session_id=session_id, symbol=symbol)
+        category = self._detect_category(fingerprint)
+        existing_accepted = [r for r in existing if r.get("accepted")]
+        category_dist = self.get_category_distribution(session_id, symbol, accepted_only=True)
+        prospective_dist = dict(category_dist)
+        prospective_dist[category] = prospective_dist.get(category, 0) + 1
+
+        if not existing:
+            return UniquenessDecision(
+                uniqueness_score=100.0,
+                diversity_score=100.0,
+                max_similarity=0.0,
+                accepted=True,
+                rejection_reason=None,
+                closest_strategy_id=None,
+                strategy_category=category,
+                category_distribution=prospective_dist,
+                fingerprint=fingerprint,
+            )
+
+        max_similarity = 0.0
+        closest_id = None
+        for rec in existing:
+            sim = self._fingerprint_similarity(fingerprint, rec.get("fingerprint", {}))
+            if sim > max_similarity:
+                max_similarity = sim
+                closest_id = rec.get("strategy_id")
+
+        uniqueness_score = round(max(0.0, (1.0 - max_similarity) * 100.0), 2)
+        accepted = max_similarity < self.similarity_reject_threshold
+        reason = None
+
+        if max_similarity >= self.duplicate_reject_threshold:
+            reason = f"Rejected as duplicate (similarity={max_similarity:.3f})"
+            accepted = False
+        elif not accepted:
+            reason = f"Rejected as highly similar (similarity={max_similarity:.3f})"
+
+        diversity_score = self._compute_diversity_score(
+            fingerprint=fingerprint,
+            existing=existing_accepted,
+            prospective_distribution=prospective_dist,
+        )
+
+        diversity_ok, diversity_reason = self._passes_diversity_rules(
+            prospective_distribution=prospective_dist,
+            accepted_count=len(existing_accepted) + 1,
+            expected_total=expected_total,
+            candidate_category=category,
+        )
+        if accepted and not diversity_ok:
+            accepted = False
+            reason = diversity_reason
+
+        return UniquenessDecision(
+            uniqueness_score=uniqueness_score,
+            diversity_score=round(diversity_score, 2),
+            max_similarity=round(max_similarity, 4),
+            accepted=accepted,
+            rejection_reason=reason,
+            closest_strategy_id=closest_id,
+            strategy_category=category,
+            category_distribution=prospective_dist,
+            fingerprint=fingerprint,
+        )
+
+    def register_strategy(
+        self,
+        strategy_id: str,
+        session_id: str,
+        symbol: str,
+        timeframe: str,
+        fingerprint: Dict[str, Any],
+        uniqueness_score: float,
+        accepted: bool,
+        rejection_reason: Optional[str] = None,
+    ) -> None:
+        """Persist strategy registry record for future comparisons."""
+        doc = {
+            "strategy_id": strategy_id,
+            "session_id": session_id,
+            "symbol": symbol.upper(),
+            "timeframe": timeframe.lower(),
+            "fingerprint": fingerprint,
+            "strategy_category": self._detect_category(fingerprint),
+            "uniqueness_score": uniqueness_score,
+            "accepted": accepted,
+            "rejection_reason": rejection_reason,
+            "created_at": datetime.now(timezone.utc).isoformat(),
+        }
+
+        self._in_memory_registry.append(doc)
+
+        if not self._mongo_enabled:
+            return
+
+        try:
+            client = MongoClient(os.environ["MONGO_URL"])
+            db = client[os.environ["DB_NAME"]]
+            db[self._registry_collection].replace_one(
+                {"strategy_id": strategy_id},
+                doc,
+                upsert=True,
+            )
+            client.close()
+        except Exception as e:
+            logger.warning(f"Failed to persist strategy registry record: {e}")
+
+    def _load_registry(self, session_id: str, symbol: str) -> List[Dict[str, Any]]:
+        symbol = symbol.upper()
+        cached = [d for d in self._in_memory_registry if d["session_id"] == session_id and d["symbol"] == symbol]
+
+        if not self._mongo_enabled:
+            return cached
+
+        try:
+            client = MongoClient(os.environ["MONGO_URL"])
+            db = client[os.environ["DB_NAME"]]
+            rows = list(
+                db[self._registry_collection].find(
+                    {"session_id": session_id, "symbol": symbol},
+                    {"_id": 0},
+                )
+            )
+            client.close()
+            return rows + cached
+        except Exception as e:
+            logger.warning(f"Falling back to in-memory registry due to DB load error: {e}")
+            return cached
+
+    def _fingerprint_similarity(self, a: Dict[str, Any], b: Dict[str, Any]) -> float:
+        """Compute weighted similarity score in [0,1]."""
+        indicator_sim = self._jaccard_similarity(
+            set(a.get("indicators", [])),
+            set(b.get("indicators", [])),
+        )
+        param_sim = self._param_similarity(a.get("parameters", {}), b.get("parameters", {}))
+        timeframe_sim = 1.0 if a.get("timeframe") == b.get("timeframe") else 0.0
+        entry_sim = 1.0 if a.get("entry_logic_type") == b.get("entry_logic_type") else 0.0
+        exit_sim = 1.0 if a.get("exit_logic_type") == b.get("exit_logic_type") else 0.0
+
+        return (
+            indicator_sim * 0.25
+            + param_sim * 0.35
+            + timeframe_sim * 0.10
+            + entry_sim * 0.20
+            + exit_sim * 0.10
+        )
+
+    def get_category_distribution(
+        self, session_id: str, symbol: str, accepted_only: bool = True
+    ) -> Dict[str, int]:
+        rows = self._load_registry(session_id=session_id, symbol=symbol)
+        if accepted_only:
+            rows = [r for r in rows if r.get("accepted")]
+        counts: Dict[str, int] = {}
+        for r in rows:
+            cat = r.get("strategy_category") or self._detect_category(r.get("fingerprint", {}))
+            counts[cat] = counts.get(cat, 0) + 1
+        return counts
+
+    def _detect_category(self, fingerprint: Dict[str, Any]) -> str:
+        indicators = set(i.lower() for i in fingerprint.get("indicators", []))
+        entry = str(fingerprint.get("entry_logic_type", "")).lower()
+        exit_logic = str(fingerprint.get("exit_logic_type", "")).lower()
+
+        if "mean_reversion" in entry or "rsi" in indicators:
+            return "mean_reversion"
+        if "breakout" in entry or "bollinger_bands" in indicators:
+            return "breakout"
+        if "volatility" in entry or ("atr" in indicators and "breakout" in exit_logic):
+            return "volatility"
+        if "trend" in entry or {"ema", "macd"} & indicators:
+            return "trend"
+        return "trend"
+
+    def _passes_diversity_rules(
+        self,
+        prospective_distribution: Dict[str, int],
+        accepted_count: int,
+        expected_total: Optional[int],
+        candidate_category: str,
+        max_category_pct: float = 0.30,
+        min_categories: int = 3,
+    ) -> Tuple[bool, Optional[str]]:
+        if accepted_count >= 10:
+            cat_count = prospective_distribution.get(candidate_category, 0)
+            if (cat_count / accepted_count) > max_category_pct:
+                return (
+                    False,
+                    f"Rejected for diversity cap: '{candidate_category}' would exceed {int(max_category_pct * 100)}%",
+                )
+
+        if expected_total:
+            represented = len([k for k, v in prospective_distribution.items() if v > 0])
+            remaining_slots = max(0, expected_total - accepted_count)
+            max_possible_categories = represented + remaining_slots
+            if max_possible_categories < min_categories:
+                return (
+                    False,
+                    f"Rejected for diversity floor: cannot reach {min_categories} categories with remaining slots",
+                )
+
+        return True, None
+
+    def _compute_diversity_score(
+        self,
+        fingerprint: Dict[str, Any],
+        existing: List[Dict[str, Any]],
+        prospective_distribution: Dict[str, int],
+    ) -> float:
+        # Category diversity: normalized entropy
+        counts = [c for c in prospective_distribution.values() if c > 0]
+        total = sum(counts)
+        if total <= 0 or len(counts) <= 1:
+            category_score = 25.0
+        else:
+            import math
+
+            probs = [c / total for c in counts]
+            entropy = -sum(p * math.log(p) for p in probs if p > 0)
+            max_entropy = math.log(4)  # trend/mean_reversion/breakout/volatility
+            category_score = min(100.0, (entropy / max_entropy) * 100.0) if max_entropy > 0 else 25.0
+
+        if not existing:
+            indicator_score = 100.0
+        else:
+            jaccards = [
+                self._jaccard_similarity(
+                    set(fingerprint.get("indicators", [])),
+                    set((r.get("fingerprint") or {}).get("indicators", [])),
+                )
+                for r in existing
+            ]
+            indicator_score = max(0.0, (1.0 - (sum(jaccards) / max(len(jaccards), 1))) * 100.0)
+
+        timeframes = {(r.get("fingerprint") or {}).get("timeframe") for r in existing}
+        timeframe_score = 100.0 if fingerprint.get("timeframe") not in timeframes else 40.0
+
+        return (category_score * 0.50) + (indicator_score * 0.35) + (timeframe_score * 0.15)
+
+    @staticmethod
+    def _jaccard_similarity(a: set, b: set) -> float:
+        if not a and not b:
+            return 1.0
+        if not a or not b:
+            return 0.0
+        return len(a.intersection(b)) / len(a.union(b))
+
+    @staticmethod
+    def _param_similarity(a: Dict[str, float], b: Dict[str, float]) -> float:
+        keys = sorted(set(a.keys()).union(b.keys()))
+        if not keys:
+            return 1.0
+        total = 0.0
+        for k in keys:
+            av = float(a.get(k, 0.5))
+            bv = float(b.get(k, 0.5))
+            total += abs(av - bv)
+        avg_distance = total / len(keys)
+        return max(0.0, 1.0 - avg_distance)
+
+
+def create_strategy_diversity_engine() -> StrategyDiversityEngine:
+    return StrategyDiversityEngine()
