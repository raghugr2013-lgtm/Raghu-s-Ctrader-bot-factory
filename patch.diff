+import sys
+from pathlib import Path
+
+sys.path.append(str(Path(__file__).resolve().parents[1]))
+
+from factory_engine import STRATEGY_TEMPLATES
+from factory_models import TemplateId
+from strategy_diversity_engine import create_strategy_diversity_engine
+
+
+def test_uniqueness_rejects_near_duplicates():
+    engine = create_strategy_diversity_engine()
+    template = STRATEGY_TEMPLATES[TemplateId.EMA_CROSSOVER]
+
+    genes = {
+        "fast_ma_period": 10,
+        "slow_ma_period": 50,
+        "atr_period": 14,
+        "stop_loss_atr_mult": 1.5,
+        "take_profit_atr_mult": 3.0,
+        "risk_per_trade_pct": 1.0,
+        "adx_threshold": 25.0,
+    }
+
+    fp1 = engine.build_fingerprint(template, genes, timeframe="1h")
+    first = engine.evaluate_uniqueness(session_id="s1", symbol="EURUSD", fingerprint=fp1)
+    assert first.accepted is True
+    assert first.uniqueness_score == 100.0
+    assert first.strategy_category == "trend"
+    assert first.diversity_score >= 0
+
+    engine.register_strategy(
+        strategy_id="strategy-a",
+        session_id="s1",
+        symbol="EURUSD",
+        timeframe="1h",
+        fingerprint=fp1,
+        uniqueness_score=first.uniqueness_score,
+        accepted=first.accepted,
+    )
+
+    fp2 = engine.build_fingerprint(template, genes, timeframe="1h")
+    second = engine.evaluate_uniqueness(session_id="s1", symbol="EURUSD", fingerprint=fp2)
+    assert second.accepted is False
+    assert second.uniqueness_score <= 5.0
+    assert second.rejection_reason is not None
+    assert second.strategy_category == "trend"
+
+
+def test_category_distribution_tracks_multiple_styles():
+    engine = create_strategy_diversity_engine()
+    session = "s2"
+    symbol = "EURUSD"
+
+    templates = [
+        TemplateId.EMA_CROSSOVER,        # trend
+        TemplateId.RSI_MEAN_REVERSION,   # mean_reversion
+        TemplateId.BOLLINGER_BREAKOUT,   # breakout
+    ]
+
+    for idx, tmpl_id in enumerate(templates):
+        template = STRATEGY_TEMPLATES[tmpl_id]
+        genes = {
+            p.name: (p.min_val + p.max_val) / 2
+            for p in template.param_definitions
+        }
+        fp = engine.build_fingerprint(template, genes, timeframe="1h")
+        decision = engine.evaluate_uniqueness(
+            session_id=session,
+            symbol=symbol,
+            fingerprint=fp,
+            expected_total=9,
+        )
+        assert decision.accepted is True
+        engine.register_strategy(
+            strategy_id=f"strategy-{idx}",
+            session_id=session,
+            symbol=symbol,
+            timeframe="1h",
+            fingerprint=fp,
+            uniqueness_score=decision.uniqueness_score,
+            accepted=decision.accepted,
+        )
+
+    dist = engine.get_category_distribution(session_id=session, symbol=symbol)
+    assert dist.get("trend", 0) >= 1
+    assert dist.get("mean_reversion", 0) >= 1
+    assert dist.get("breakout", 0) >= 1
